# Public site URL (set to your Vercel domain or custom domain — required for SEO/sitemap)
NEXT_PUBLIC_SITE_URL=https://tropical-herbs-uw5g.vercel.app

# Supabase — paste these in Vercel Environment Variables
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin panel password (choose a strong password)
ADMIN_PASSWORD=your-secure-password-here
ADMIN_SECRET=random-secret-string-change-this
